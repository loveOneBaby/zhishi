{
  "name": "interview-knowledge-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "面试知识快速检索 - 桌面端 Electron 壳",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/generate-icons.cjs",
    "dmg:background": "swift scripts/generate-dmg-background.swift",
    "dist:dmg": "electron-builder --mac dmg --publish never",
    "dist:publish": "electron-builder --mac --publish always"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.interviewknowledge.search",
    "productName": "知识检索",
    "asar": false,
    "afterPack": "scripts/after-pack.cjs",
    "directories": {
      "output": "../release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "loveOneBaby",
        "repo": "zhishi",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../server/package.json",
        "to": "server/package.json"
      },
      {
        "from": "../server/dist",
        "to": "server/dist"
      },
      {
        "from": "../server/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "../web/dist",
        "to": "web/dist"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "artifactName": "${name}-${version}-${arch}-mac.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "${name}-${version}.${ext}",
      "title": "双击知识检索.app 自动安装 ${version}",
      "background": "assets/dmg-background.png",
      "iconSize": 96,
      "iconTextSize": 13,
      "window": {
        "width": 620,
        "height": 360
      },
      "contents": [
        {
          "x": 310,
          "y": 170,
          "type": "file"
        }
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
