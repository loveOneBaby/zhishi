# 服务端口（前端构建产物也由它托管）
PORT=5173

# SQLite 数据库文件路径（默认 server/data/knowledge.db）
# DB_PATH=./data/knowledge.db

# —— AI：问答 + 生成知识点（可选）——
# 默认按百炼 / DashScope Qwen 的 OpenAI-compatible 接口调用。
# 配置后可在知识库页用「AI 生成知识点」直接生成内容、面试考点、追问和易错点。
AI_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus
AI_TEMPERATURE=0.35
