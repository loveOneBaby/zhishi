# 服务端口（前端构建产物也由它托管）
PORT=5173

# ───────────────────────── 数据库 ─────────────────────────
# 统一用 libSQL（@libsql/client）。按场景二选一：
#
# 1) 本地场景（默认，离线、零网络、可直接读现有 server/data/knowledge.db）：
#      不设置下面任何变量即可，默认 file:./data/knowledge.db
#      也可显式 DB_PATH=./data/knowledge.db （兼容旧变量，会转成 file: 前缀）
#
# 2) 远程场景（Render / Turso 等线上部署，数据持久、跨实例共享）：
#      TURSO_DATABASE_URL=libsql://<your-db>.turso.io
#      TURSO_AUTH_TOKEN=<token>
#    创建方式见 README「部署到 Render + Turso」一节。
# DB_PATH=./data/knowledge.db
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# —— AI：问答 + 生成知识点（可选）——
# 默认按百炼 / DashScope Qwen 的 OpenAI-compatible 接口调用。
# 配置后可在知识库页用「AI 生成知识点」直接生成内容、面试考点、追问和易错点。
AI_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus
AI_TEMPERATURE=0.35

# AI 图解生成：复用同一个 AI_API_KEY，默认走百炼 Qwen Image 原生接口。
AI_IMAGE_ENABLED=true
AI_IMAGE_MODEL=qwen-image-2.0-pro
#AI_IMAGE_MODEL=kling/kling-v3-image-generation
AI_IMAGE_SIZE=1664*928
# AI_IMAGE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
